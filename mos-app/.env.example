# Local Supabase stack (supabase/config.toml: api :55321). Committed local-dev values only — NO prod secrets.
VITE_SUPABASE_URL=http://127.0.0.1:55321
# Local anon key (well-known public local-dev constant printed by `supabase status`). Replace per-env in deploy.
VITE_SUPABASE_ANON_KEY=<paste `supabase status` anon key here>
